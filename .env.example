# ─── Database (Neon Postgres + pgvector) ──────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/retailer?sslmode=disable"

# ─── Queue (Upstash Redis / local Redis) ──────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Dev / testing (dashboard) ─────────────────────────────────────────
# Shows "Crawl now" on Competitors. Remove or set false before launch.
ENABLE_DEV_CRAWL_NOW="false"
# Ops rollback UI + discovery cost on /status. Requires explicit enable in production.
ENABLE_OPS_UI="false"
# Comma-separated Clerk user IDs or emails allowed to use ops surfaces (required when ENABLE_OPS_UI=true).
OPS_ADMIN_USER_IDS=""
OPS_ADMIN_EMAILS=""

# ─── Object storage (Vercel Blob) ─────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ─── AI (Vercel AI Gateway) ───────────────────────────────────────────
AI_GATEWAY_API_KEY=""
AI_EXTRACTION_MODEL="openai/gpt-4o-mini"
AI_EMBEDDING_MODEL="openai/text-embedding-3-small"

# ─── Auth (Clerk) ─────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ─── Billing (Stripe) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PRICE_STARTER=""
NEXT_PUBLIC_STRIPE_PRICE_GROWTH=""
NEXT_PUBLIC_STRIPE_PRICE_SCALE=""

# ─── Email / reports (Resend) ─────────────────────────────────────────
RESEND_API_KEY=""
REPORTS_FROM_EMAIL="intelligence@retailer.example"

# ─── Crawler ──────────────────────────────────────────────────────────
CRAWLER_USER_AGENT="RetAIlerBot/0.1 (+https://retailer.example/bot)"
CRAWLER_PROXY_URL=""
CRAWLER_MAX_CONCURRENCY="2"
# Parallel platform-pack + static discovery in discover-config worker (Phase 1.3)
DISCOVERY_ORCHESTRATOR="0"

# ─── App URLs ─────────────────────────────────────────────────────────
NEXT_PUBLIC_DASHBOARD_URL="http://localhost:3000"
NEXT_PUBLIC_WEB_URL="http://localhost:3001"
