{
  "name": "@retailer/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "nodemon --watch src --watch ../../packages --ext ts,tsx --ignore '**/node_modules/**' --ignore '**/.next/**' --ignore '**/.turbo/**' --exec 'tsx src/index.ts'",
    "dev:stable": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "enqueue": "tsx src/enqueue.ts",
    "purge-queues": "tsx src/purge-queues.ts",
    "kill": "pkill -9 -f 'RetAIler/apps/worker.*tsx' 2>/dev/null; pkill -9 -f 'RetAIler/apps/worker.*nodemon' 2>/dev/null; pkill -9 -f '@retailer/worker dev' 2>/dev/null; echo 'Worker processes stopped'",
    "lint": "echo \"(worker) no lint configured\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clerk/backend": "^1.21.4",
    "@retailer/analytics": "workspace:*",
    "@retailer/core": "workspace:*",
    "@retailer/crawler": "workspace:*",
    "@retailer/db": "workspace:*",
    "@retailer/jobs": "workspace:*",
    "@retailer/pipeline": "workspace:*",
    "@retailer/reports": "workspace:*",
    "@retailer/schema": "workspace:*",
    "dotenv": "^16.4.5",
    "playwright": "1.60.0",
    "react": "^19.0.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "nodemon": "^3.1.9",
    "typescript": "^5.6.3"
  }
}
