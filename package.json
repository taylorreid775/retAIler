{
  "name": "retailer",
  "version": "0.1.0",
  "private": true,
  "description": "RetAIler — Canadian retail competitive-intelligence platform",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @retailer/db db:generate",
    "db:migrate": "pnpm --filter @retailer/db db:migrate",
    "db:push": "pnpm --filter @retailer/db db:push",
    "db:seed": "pnpm --filter @retailer/db db:seed",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  }
}
